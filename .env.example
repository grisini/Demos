# Local development
PORT=5173
DATA_SOURCE=local
AUTH_MODE=demo

# Supabase prototype connection.
# Keep anon key public-only. Never put service_role in frontend config.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Future SI-PASS test integration placeholders.
SIPASS_ENV=test
SIPASS_AUTHORITY=https://sicas-test.sigov.si/
SIPASS_CLIENT_ID=
SIPASS_REDIRECT_URI=http://localhost:5173/auth/sipass/callback


{
  "crons": [
    {
      "path": "/api/notifications/daily-digest",
      "schedule": "10 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/config.local.js",
      "destination": "/api/config.local"
    },
    {
      "source": "/api/initiatives",
      "destination": "/api/initiatives/create"
    }
  ]
}
